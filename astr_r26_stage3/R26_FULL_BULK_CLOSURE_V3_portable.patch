+        t6=4.d0*muv*t6/(pv*rhov)
+        t7=7.d0*muv*delv*(divs(a)/rhov-2.d0*grt(a))/(3.d0*pv)
+        t8=-2.d0*t8/(15.d0*rhov)
+        om(a)=-7.d0*muv*(ddelta(ii,jj,kk,a)/rhov-delv*grho(a)/(rhov*rhov))/3.d0 &
+              +t1+t2+t3+t4+t5+t6+t7+t8
+      enddo
+      omega(ii,jj,kk,1:3)=om
+    enddo; enddo; enddo
+  end subroutine r26_full_omega_closure
+
+
 end module methodmoment
